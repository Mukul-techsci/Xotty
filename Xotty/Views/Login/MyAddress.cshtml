@model List<EntityLayer.enAddress>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <div class="d-flex justify-content-between mb-4">
        <h2>My Addresses</h2>

        <button class="btn btn-success"
                data-bs-toggle="modal"
                data-bs-target="#addressModal">
            + Add New Address
        </button>
    </div>

    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">

                <div class="card shadow border-0 rounded-4 p-3 h-100">

                    <div class="d-flex justify-content-between">

                        <span class="badge bg-dark">
                            @item.AddressType
                        </span>

                        @if (item.IsDefault)
                        {
                            <span class="badge bg-success">
                                Default
                            </span>
                        }

                    </div>

                    <h5 class="mt-3 fw-bold">
                        @item.FullName
                    </h5>

                    <p>
                        @item.MobileNo
                    </p>

                    <p>
                        @item.AddressLine,
                        @item.City,
                        @item.StateName - @item.Pincode
                    </p>

                    <div class="mt-auto d-flex gap-2">

                        <button class="btn btn-outline-danger w-50"
                                onclick="DeleteAddress(@item.Id)">
                            Delete
                        </button>

                        <button class="btn btn-outline-primary w-50">
                            Update
                        </button>

                    </div>

                </div>

            </div>
        }

    </div>

</div>

<div class="modal fade" id="addressModal">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <h5>Add Address</h5>
            </div>

            <div class="modal-body">

                <input type="hidden" id="AddressId" />

                <div class="row">

                    <div class="col-md-6 mb-3">
                        <input type="text"
                               id="FullName"
                               class="form-control"
                               placeholder="Full Name" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <input type="text"
                               id="MobileNo"
                               class="form-control"
                               placeholder="Mobile Number" />
                    </div>

                    <div class="col-md-12 mb-3">
                        <textarea id="AddressLine"
                                  class="form-control"
                                  placeholder="Address"></textarea>
                    </div>

                    <div class="col-md-4 mb-3">
                        <input type="text"
                               id="City"
                               class="form-control"
                               placeholder="City" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <input type="text"
                               id="StateName"
                               class="form-control"
                               placeholder="State" />
                    </div>

                    <div class="col-md-4 mb-3">
                        <input type="text"
                               id="Pincode"
                               class="form-control"
                               placeholder="Pincode" />
                    </div>

                    <div class="col-md-6 mb-3">

                        <select id="AddressType" class="form-control">
                            <option>Home</option>
                            <option>Office</option>
                        </select>

                    </div>

                    <div class="col-md-6 mt-2">

                        <input type="checkbox" id="IsDefault" />
                        Set As Default Address

                    </div>

                </div>

            </div>

            <div class="modal-footer">

                <button class="btn btn-success"
                        onclick="SaveAddress()">
                    Save Address
                </button>

            </div>

        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script>

    function SaveAddress() {

        var model = {
            Id: $('#AddressId').val(),
            FullName: $('#FullName').val(),
            MobileNo: $('#MobileNo').val(),
            AddressLine: $('#AddressLine').val(),
            City: $('#City').val(),
            StateName: $('#StateName').val(),
            Pincode: $('#Pincode').val(),
            AddressType: $('#AddressType').val(),
            IsDefault: $('#IsDefault').is(':checked')
        };

        $.ajax({
            url: '/Login/SaveAddress',
            type: 'POST',
            data: model,
            success: function (response) {

                alert(response[0].message);

                location.reload();
            }
        });
    }

    function DeleteAddress(id) {

        if (confirm('Are you sure want to delete?')) {

            $.ajax({
                url: '/Login/DeleteAddress',
                type: 'POST',
                data: { id: id },
                success: function (response) {

                    alert(response[0].message);

                    location.reload();
                }
            });
        }
    }

</script>
